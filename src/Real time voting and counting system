        "[INFO] Exit passed for Voter ID %d.\n",
        voter_db[voter_idx].voter_id);
    return 1;
}

/* ══════════════════════════════════════════════════════════
   MAIN
   ══════════════════════════════════════════════════════════ */
int main(void)
{
    int i;
    struct sched_param sp = { .sched_priority = 5 };
    pthread_setschedparam(pthread_self(), SCHED_FIFO, &sp);

    srand((unsigned)time(NULL));

    make_mutex(&vote_mutex);
    make_mutex(&log_mutex);
    make_mutex(&pipe_mutex);
    make_mutex(&auth_mutex);
    make_mutex(&rate_mutex);

    window_start = time(NULL);

    log_fp = fopen("/tmp/vote_audit.log", "w");
    setup_pipes();

    chid = ChannelCreate(0);
    if (chid == -1) { perror("ChannelCreate"); return 1; }

    printf("\n╔══════════════════════════════════════╗\n");
    printf("║    Secure Real-Time Voting System    ║\n");
    printf("║         By Team Genz Coders          ║\n");
    printf("╚══════════════════════════════════════╝\n\n");

    /* Admin login */
    int attempts = 0;
    while (1) {
        char pwd[32];
        printf("Admin password: ");
        fflush(stdout);
        if (scanf("%31s", pwd) != 1) continue;
        { int c;
          while ((c = getchar()) != '\n' && c != EOF); }
        if (strcmp(pwd, ADMIN_PASSWORD) == 0) {
            printf("[SYSTEM] Login successful!\n");
            break;
        }
        if (++attempts >= 3) {
            printf("[SYSTEM] Too many attempts. Locked: ");
            fflush(stdout);
            int t;
            for (t = 30; t >= 0; t--) {
                printf("%d ", t);
                fflush(stdout);
                if (t > 0) sleep(1);
            }
            printf("\n");
            attempts = 0;
        } else {
            printf("[SYSTEM] Wrong password!\n");
        }
    }

    register_voters();
    admin_menu();

    if (candidate_count == 0 || voter_count == 0)
        goto cleanup;

    voting_open = 1;
    time_left   = VOTING_DURATION_SEC;

    printf("\n[SYSTEM] Voting is now OPEN! (%d sec)\n\n",
           VOTING_DURATION_SEC);
    pipe_write(fd_admin, "[INFO] Voting session started.\n");
    broadcast_live();

    pthread_t counter_tid, timer_tid;
    pthread_create(&counter_tid, NULL, counter_task, NULL);
    pthread_create(&timer_tid,   NULL, timer_task,   NULL);

    int coid = ConnectAttach(0, getpid(), chid,
                             _NTO_SIDE_CHANNEL, 0);
    if (coid == -1) { perror("ConnectAttach"); goto cleanup; }

    /* ── Main voting loop ───────────────────────────────── */
    while (voting_open) {

        /* Step 1 — Voter ID */
        int voter_idx = step1_enter_voter_id();
        if (voter_idx == -1) continue;

        /* Step 2 — Face scan */
        if (!step2_face_verification(voter_idx)) continue;

        /* Authenticated — close door */
        door_closed();

        /* Candidate selection */
        printf("\n╔══════════════════════════════════╗\n");
        printf("║        SELECT A CANDIDATE        ║\n");
        printf("╠══════════════════════════════════╣\n");
        for (i = 0; i < candidate_count; i++)
            printf("║  %d. %-28s ║\n",
                   i + 1, candidates[i].name);
        printf("╚══════════════════════════════════╝\n");
        printf("  Enter choice (1-%d): ", candidate_count);
        fflush(stdout);

        int choice = 0;
        if (scanf("%d", &choice) != 1 ||
            choice < 1 || choice > candidate_count) {
            printf("  Invalid. Vote cancelled.\n\n");
            int c;
            while ((c = getchar()) != '\n' && c != EOF);
            if (exit_face(voter_idx)) door_open();
            else printf("  Exit failed - door locked.\n\n");
            continue;
        }
        { int c; while ((c = getchar()) != '\n' && c != EOF); }

        /* Send vote via QNX IPC MsgSend */
        vote_msg_t vmsg = {
            .type          = MSG_VOTE,
            .voter_idx     = voter_idx,
            .candidate_idx = choice - 1,
        };
        vote_reply_t vrep = {0};

        if (MsgSend(coid, &vmsg, sizeof(vmsg),
                    &vrep, sizeof(vrep)) == -1) {
            perror("MsgSend");
            if (exit_face(voter_idx)) door_open();
            continue;
        }

        if (vrep.ok) {
            printf("\n");
            printf("╔══════════════════════════════╗\n");
            printf("║   VOTE CASTED SUCCESSFULLY   ║\n");
            printf("╚══════════════════════════════╝\n\n");

            pthread_mutex_lock(&vote_mutex);
            printf("  Total voted : %d / %d\n",
                   total_votes, voter_count);
            pthread_mutex_unlock(&vote_mutex);
            printf("\n");

            /* Rate limit checked HERE, after successful vote */
            check_rate_limit();

        } else {
            printf("\n  [BLOCKED] %s\n\n",
                   block_reason_str(vrep.block_reason));
        }
        fflush(stdout);

        /* Exit verification */
        if (exit_face(voter_idx))
            door_open();
        else {
            printf("  Exit failed - door locked."
                   " Admin alerted.\n\n");
            pipe_write(fd_admin,
                "[ALERT] Exit failed. Door locked.\n");
            audit("EXIT_FAIL_LOCKED",
                  voter_db[voter_idx].voter_id, NULL);
        }

        /* Admin end check */
        if (voting_open) {
            printf("  Type 'end' to stop voting or"
                   " press Enter to continue: ");
            fflush(stdout);
            char cmd[16];
            if (scanf("%15s", cmd) == 1 &&
                strcmp(cmd, "end") == 0) {
                printf("  Admin password: ");
                fflush(stdout);
                char apwd[32];
                if (scanf("%31s", apwd) == 1 &&
                    strcmp(apwd, ADMIN_PASSWORD) == 0) {
                    voting_open = 0;
                    printf("\n[ADMIN] Voting ended.\n");
                } else {
                    printf("  Wrong password."
                           " Voting continues.\n\n");
                }
            }
            { int c;
              while ((c = getchar()) != '\n'
                     && c != EOF); }
        }
    }

    ConnectDetach(coid);
    pthread_join(timer_tid, NULL);
    send_stop();
    pthread_join(counter_tid, NULL);

    print_results();

cleanup:
    if (log_fp) {
        fprintf(log_fp, "\n=== SESSION END ===\n");
        fclose(log_fp);
    }
    pthread_mutex_destroy(&vote_mutex);
    pthread_mutex_destroy(&log_mutex);
    pthread_mutex_destroy(&pipe_mutex);
    pthread_mutex_destroy(&auth_mutex);
    pthread_mutex_destroy(&rate_mutex);
    ChannelDestroy(chid);
    if (fd_admin >= 0) close(fd_admin);
    if (fd_live  >= 0) close(fd_live);
    printf("\n[SYSTEM] Audit log: /tmp/vote_audit.log\n");
    return 0;
}

static const char *block_reason_str(int reason)
{
    switch (reason) {
    case BLOCK_UNKNOWN_VOTER:  return "Voter not found in database";
    case BLOCK_ALREADY_VOTED:  return "Voter has already cast their vote";
    case BLOCK_BAD_CANDIDATE:  return "Selected candidate number is invalid";
    case BLOCK_FACE_FAIL:      return "Face verification failed";
    default:                   return "Unknown reason";
    }
}


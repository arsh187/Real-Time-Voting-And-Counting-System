/* ══════════════════════════════════════════════════════════
   COUNTER TASK — HIGH priority 25
   ══════════════════════════════════════════════════════════ */
void *counter_task(void *arg)
{
    (void)arg;
    struct sched_param sp = { .sched_priority = 25 };
    pthread_setschedparam(pthread_self(), SCHED_FIFO, &sp);

    vote_msg_t   msg;
    vote_reply_t rep;
    int rcvid;

    while (1) {
        rcvid = MsgReceive(chid, &msg, sizeof(msg), NULL);
        if (rcvid <= 0) continue;

        if (msg.type == MSG_STOP) {
            rep.ok = 0;
            rep.block_reason = BLOCK_NONE;
            MsgReply(rcvid, 0, &rep, sizeof(rep));
            break;
        }

        pthread_mutex_lock(&vote_mutex);

        int vidx    = msg.voter_idx;
        int cidx    = msg.candidate_idx;
        int ok      = 0;
        int breason = BLOCK_NONE;
        char voter_name[30] = {0};
        char cand_name[50]  = {0};

        if (vidx < 0 || vidx >= voter_count) {
            breason = BLOCK_UNKNOWN_VOTER;
        } else if (voter_db[vidx].has_voted) {
            breason = BLOCK_ALREADY_VOTED;
            strncpy(voter_name, voter_db[vidx].name, 29);
            audit("DUPLICATE_VOTE",
                  voter_db[vidx].voter_id, NULL);
        } else if (cidx < 0 || cidx >= candidate_count) {
            breason = BLOCK_BAD_CANDIDATE;
        } else {
            voter_db[vidx].has_voted = 1;
            candidates[cidx].votes++;
            total_votes++;
            ok = 1;
            strncpy(voter_name, voter_db[vidx].name, 29);
            strncpy(cand_name,  candidates[cidx].name, 49);
            audit("VOTE_CAST",
                  voter_db[vidx].voter_id, cand_name);
        }

        pthread_mutex_unlock(&vote_mutex);

        rep.ok = ok;
        rep.block_reason = breason;
        MsgReply(rcvid, ok, &rep, sizeof(rep));

        if (ok) {
            pipe_writef(fd_admin,
                "[INFO] Vote counted: Voter=%s\n",
                voter_name);
            broadcast_live();
        } else {
            pipe_writef(fd_admin,
                "[ALERT] Vote BLOCKED - %s\n",
                block_reason_str(breason));
        }
    }
    return NULL;
}

/* ══════════════════════════════════════════════════════════
   TIMER TASK — priority 10 (silent, pipe only)
   ══════════════════════════════════════════════════════════ */
void *timer_task(void *arg)
{
    (void)arg;
    struct sched_param sp = { .sched_priority = 10 };
    pthread_setschedparam(pthread_self(), SCHED_FIFO, &sp);

    int i;
    for (i = VOTING_DURATION_SEC; i > 0 && voting_open; i--) {
        time_left = i;
        broadcast_live();
        sleep(1);
    }
    if (voting_open) {
        voting_open = 0;
        printf("\n[TIMER] Voting time expired!\n");
        pipe_write(fd_admin,
            "[ALERT] Voting expired. Polls closed.\n");
    }
    return NULL;
}

/* ── Print final results ────────────────────────────────── */
static void print_results(void)
{
    int i;
    pthread_mutex_lock(&vote_mutex);
    int total  = total_votes;
    int winner = 0;
    for (i = 1; i < candidate_count; i++)
        if (candidates[i].votes > candidates[winner].votes)
            winner = i;

    printf("\n╔══════════════════════════════════╗\n");
    printf("║         FINAL RESULTS            ║\n");
    printf("╠══════════════════════════════════╣\n");
    for (i = 0; i < candidate_count; i++) {
        int pct = total > 0
                  ? candidates[i].votes * 100 / total : 0;
        printf("║  %-15s : %3d votes %2d%% ║\n",
               candidates[i].name,
               candidates[i].votes, pct);
    }
    printf("╠══════════════════════════════════╣\n");
    printf("║  Total Votes : %-4d              ║\n", total);
    if (total > 0)
        printf("║  WINNER      : %-15s     ║\n",
               candidates[winner].name);
    printf("╚══════════════════════════════════╝\n");

    pipe_writef(fd_admin, "\n=== FINAL RESULTS ===\n");
    for (i = 0; i < candidate_count; i++)
        pipe_writef(fd_admin, "%s : %d votes\n",
                    candidates[i].name,
                    candidates[i].votes);
    if (total > 0)
        pipe_writef(fd_admin, "WINNER: %s\n",
                    candidates[winner].name);

    pthread_mutex_unlock(&vote_mutex);
}

/* ── Send stop to counter ───────────────────────────────── */
static void send_stop(void)
{
    int coid = ConnectAttach(0, getpid(), chid,
                             _NTO_SIDE_CHANNEL, 0);
    if (coid == -1) return;
    vote_msg_t   msg = { .type = MSG_STOP };
    vote_reply_t rep = {0};
    MsgSend(coid, &msg, sizeof(msg), &rep, sizeof(rep));
    ConnectDetach(coid);
}


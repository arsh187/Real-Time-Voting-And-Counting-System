/* ══════════════════════════════════════════════════════════
   RATE LIMITER
   Called AFTER a successful vote is cast.
   Locks for RATE_LIMIT_BLOCK (10) seconds and shows a
   live countdown bar on the console each second.
   ══════════════════════════════════════════════════════════ */
static void check_rate_limit(void)
{
    pthread_mutex_lock(&rate_mutex);
    time_t now = time(NULL);

    /* Reset window if 60 seconds have passed */
    if (now - window_start >= RATE_LIMIT_WINDOW) {
        vote_count_minute = 0;
        window_start      = now;
    }

    vote_count_minute++;

    if (vote_count_minute > RATE_LIMIT_VOTES) {
        pthread_mutex_unlock(&rate_mutex);

        /* ── Lockout banner ── */
        printf("\n");
        printf("╔══════════════════════════════════════════╗\n");
        printf("║   RATE LIMIT REACHED — SYSTEM LOCKED    ║\n");
        printf("║   %d votes cast within %d seconds        ║\n",
               RATE_LIMIT_VOTES, RATE_LIMIT_WINDOW);
        printf("║   Booth locked for %2d seconds            ║\n",
               RATE_LIMIT_BLOCK);
        printf("╠══════════════════════════════════════════╣\n");

        pipe_writef(fd_admin,
            "[ALERT] Rate limit hit. Booth locked %ds.\n",
            RATE_LIMIT_BLOCK);

        /* ── Compact countdown — all on one line: 10 9 8 … 0 ── */
        int i;
        printf("  Resuming in: ");
        fflush(stdout);
        for (i = RATE_LIMIT_BLOCK; i >= 0; i--) {
            printf("%d ", i);
            fflush(stdout);
            if (i > 0) sleep(1);
        }
        printf("\n");

        printf("╚══════════════════════════════════════════╝\n");
        printf("[SYSTEM] Lockout cleared. Voting resumed.\n\n");

        pipe_write(fd_admin,
            "[INFO] Rate-limit pause ended. Resumed.\n");

        /* Reset counters */
        pthread_mutex_lock(&rate_mutex);
        vote_count_minute = 0;
        window_start      = time(NULL);
    }

    pthread_mutex_unlock(&rate_mutex);
}


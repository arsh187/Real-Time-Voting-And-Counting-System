    pthread_mutex_unlock(&auth_mutex);

    if (found == -1) {
        printf("  Voter ID %d not found.\n\n", voter_id);
        pipe_writef(fd_admin,
            "[ALERT] Unknown Voter ID %d attempted.\n",
            voter_id);
        audit("UNKNOWN_VOTER", voter_id, NULL);
        return -1;
    }

    pthread_mutex_lock(&vote_mutex);
    int already = voter_db[found].has_voted;
    char vname[30];
    strncpy(vname, voter_db[found].name, 29);
    pthread_mutex_unlock(&vote_mutex);

    if (already) {
        fraud_lockdown(voter_id, vname);
        return -1;
    }

    printf("  Welcome %s!\n", voter_db[found].name);
    return found;
}


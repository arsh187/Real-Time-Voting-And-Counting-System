/* ── Priority-inherit mutex ─────────────────────────────── */
static void make_mutex(pthread_mutex_t *m)
{
    pthread_mutexattr_t a;
    pthread_mutexattr_init(&a);
    pthread_mutexattr_setprotocol(&a, PTHREAD_PRIO_INHERIT);
    pthread_mutex_init(m, &a);
    pthread_mutexattr_destroy(&a);
}

/* ── Pipe write helpers ─────────────────────────────────── */
static void pipe_write(int fd, const char *msg)
{
    if (fd < 0) return;
    pthread_mutex_lock(&pipe_mutex);
    ssize_t r = write(fd, msg, strlen(msg));
    (void)r;
    pthread_mutex_unlock(&pipe_mutex);
}

static void pipe_writef(int fd, const char *fmt, ...)
{
    char buf[512];
    va_list ap;
    va_start(ap, fmt);
    vsnprintf(buf, sizeof(buf), fmt, ap);
    va_end(ap);
    pipe_write(fd, buf);
}

/* ── Pipe setup ─────────────────────────────────────────── */
static void setup_pipes(void)
{
    const char *pipes[] = {PIPE_ADMIN, PIPE_LIVE};
    int i;
    for (i = 0; i < 2; i++) {
        unlink(pipes[i]);
        mkfifo(pipes[i], 0666);
    }
    fd_admin = open(PIPE_ADMIN, O_RDWR | O_NONBLOCK);
    fd_live  = open(PIPE_LIVE,  O_RDWR | O_NONBLOCK);

    if (fd_admin < 0 || fd_live < 0)
        printf("[WARNING] One or more pipes failed.\n");
}

/* ── Audit log ──────────────────────────────────────────── */
static void audit(const char *event, int voter_id,
                  const char *candidate)
{
    if (!log_fp) return;
    time_t now = time(NULL);
    char ts[32];
    strftime(ts, sizeof(ts), "%Y-%m-%d %H:%M:%S",
             localtime(&now));
    pthread_mutex_lock(&log_mutex);
    fprintf(log_fp,
            "[%s] EVENT=%-25s VOTER=%d CANDIDATE=%s\n",
            ts, event, voter_id,
            candidate ? candidate : "-");
    fflush(log_fp);
    pthread_mutex_unlock(&log_mutex);
}

/* ── Live dashboard (pipe only) ─────────────────────────── */
static void broadcast_live(void)
{
    char buf[1024];
    char ts[32];
    time_t now = time(NULL);
    int i, tv, tl;

    pthread_mutex_lock(&vote_mutex);
    tv = total_votes;
    tl = time_left;
    pthread_mutex_unlock(&vote_mutex);

    strftime(ts, sizeof(ts), "%H:%M:%S", localtime(&now));

    snprintf(buf, sizeof(buf),
        "\033[2J\033[H"
        "╔══════════════════════════════╗\n"
        "║   LIVE VOTING DASHBOARD      ║\n"
        "╠══════════════════════════════╣\n"
        "║  Total Voted : %-4d          ║\n"
        "║  Time Left   : %-4d sec      ║\n"
        "║  Last update : %s            ║\n"
        "╠══════════════════════════════╣\n",
        tv, tl, ts);

    for (i = 0; i < candidate_count; i++) {
        char line[64];
        int pct = tv > 0
                  ? candidates[i].votes * 100 / tv : 0;
        snprintf(line, sizeof(line),
                 "║  %-15s : %3d (%2d%%)  ║\n",
                 candidates[i].name,
                 candidates[i].votes, pct);
        strncat(buf, line, sizeof(buf) - strlen(buf) - 1);
    }
    strncat(buf, "╚══════════════════════════════╝\n",
            sizeof(buf) - strlen(buf) - 1);
    pipe_write(fd_live, buf);
}


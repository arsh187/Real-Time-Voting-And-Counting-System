/* ── Step 1: Voter ID ───────────────────────────────────── */
static int step1_enter_voter_id(void)
{
    int voter_id = 0;

    printf("╔════════════════════════════╗\n");
    printf("║    ENTER YOUR VOTER ID     ║\n");
    printf("╚════════════════════════════╝\n");
    printf("  Voter IDs: 101 to 117\n");
    printf("  Enter Voter ID: ");
    fflush(stdout);

    if (scanf("%d", &voter_id) != 1) {
        int c;
        while ((c = getchar()) != '\n' && c != EOF);
        printf("  [ERROR] Please enter a number.\n\n");
        return -1;
    }
    { int c; while ((c = getchar()) != '\n' && c != EOF); }

    int i, found = -1;
    pthread_mutex_lock(&auth_mutex);
    for (i = 0; i < voter_count; i++) {
        if (voter_db[i].voter_id == voter_id) {
            found = i; break;
        }
